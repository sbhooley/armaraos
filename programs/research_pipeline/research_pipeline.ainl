# Research pipeline (showcase)
# Deterministic: GitHub repository search for a query from frame extra, plus counts.
# Optional: extra.use_llm == "yes" adds a short LLM summary (requires provider keys).
#
# extra.research_query must be URL-safe (ASCII, no spaces) — e.g. "armaraos", "ainl", "rust+cli".
# Curated cron passes a LearningFrame v1 with extra (see frame.example.json).
# Uses: http, core, llm/openrouter
# Validate: ainl validate programs/research_pipeline/research_pipeline.ainl --strict

research_pipeline:
  research_query = core.GET extra research_query
  use_llm = core.GET extra use_llm
  ts = core.NOW 0

  url = core.CONCAT "https://api.github.com/search/repositories?q=" research_query "&per_page=1"
  repos = http.GET url
  total = core.GET repos total_count
  items = core.GET repos items
  top = core.GET items "0"
  repo_name = core.GET top full_name
  html_url = core.GET top html_url

  if use_llm == "yes":
    prompt = core.CONCAT "In 2 bullets, summarize why a developer might care about repo " repo_name " URL " html_url
    brief = llm.COMPLETION prompt
    out {pipeline: "research", query: research_query, total_count: total, top_repo: repo_name, top_url: html_url, llm_brief: brief, source: "api.github.com", generated_at: ts}

  if use_llm != "yes":
    out {pipeline: "research", query: research_query, total_count: total, top_repo: repo_name, top_url: html_url, source: "api.github.com", generated_at: ts}
