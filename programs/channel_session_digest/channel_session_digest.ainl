# ArmaraOS multi-channel digest (showcase)
# ==========================================
# Every 6 hours: aggregates loopback API signals for agents, channel adapters,
# workflows, and daemon health into one JSON snapshot. The kernel appends
# stdout (--json) to the owning agent session (inbox-style; no LLM turn).
#
# GET /api/agents returns a JSON array — use core.LEN for counts.
# GET /api/workflows returns a JSON array.
# GET /api/channels returns { channels, total, configured_count }.
#
# Uses: http, core
# Validate: ainl validate programs/channel_session_digest/channel_session_digest.ainl --strict

channel_session_digest:
  ts = core.NOW 0
  health = http.GET "http://127.0.0.1:4200/api/health"
  agents = http.GET "http://127.0.0.1:4200/api/agents"
  channels_resp = http.GET "http://127.0.0.1:4200/api/channels"
  workflows = http.GET "http://127.0.0.1:4200/api/workflows"

  daemon_status = core.GET health status
  agent_count = core.LEN agents
  channel_catalog_size = core.GET channels_resp total
  channels_configured = core.GET channels_resp configured_count
  workflow_count = core.LEN workflows

  out {digest_version: 2, daemon_status: daemon_status, active_agents: agent_count, channel_adapters_catalog: channel_catalog_size, channels_configured: channels_configured, workflows_defined: workflow_count, generated_at: ts}
