# OpenFang Environment Variables
# Copy this file to .env and fill in your values.
# Only set the providers you plan to use.

# ─── LLM Provider API Keys ───────────────────────────────────────────

# Anthropic (Claude models)
# ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini
# GEMINI_API_KEY=AIza...
# GOOGLE_API_KEY=AIza...          # Alternative to GEMINI_API_KEY

# OpenAI
# OPENAI_API_KEY=sk-...

# Groq (fast inference)
# GROQ_API_KEY=gsk_...

# DeepSeek
# DEEPSEEK_API_KEY=sk-...

# OpenRouter (multi-provider gateway)
# OPENROUTER_API_KEY=sk-or-...

# Together AI
# TOGETHER_API_KEY=...

# Mistral AI
# MISTRAL_API_KEY=...

# Fireworks AI
# FIREWORKS_API_KEY=...

# ─── Local LLM Providers (no API key needed) ─────────────────────────

# Ollama (default: http://localhost:11434)
# OLLAMA_BASE_URL=http://localhost:11434

# vLLM (default: http://localhost:8000)
# VLLM_BASE_URL=http://localhost:8000

# LM Studio (default: http://localhost:1234)
# LMSTUDIO_BASE_URL=http://localhost:1234

# ─── Channel Tokens ──────────────────────────────────────────────────

# Telegram
# TELEGRAM_BOT_TOKEN=123456:ABC-...

# Discord
# DISCORD_BOT_TOKEN=...

# Slack
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...

# WhatsApp (via Cloud API)
# WHATSAPP_TOKEN=...
# WHATSAPP_PHONE_ID=...

# Signal
# SIGNAL_CLI_PATH=/usr/local/bin/signal-cli
# SIGNAL_PHONE_NUMBER=+1...

# Matrix
# MATRIX_HOMESERVER=https://matrix.org
# MATRIX_ACCESS_TOKEN=...

# Email (IMAP/SMTP)
# EMAIL_IMAP_HOST=imap.gmail.com
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_USERNAME=...
# EMAIL_PASSWORD=...

# ─── AINL graph memory (openfang-runtime, dashboard chat) ────────────
# Per-agent SQLite: ~/.armaraos/agents/<id>/ainl_memory.db — see docs/graph-memory.md
# Persona axis hook vs evolution pass: docs/persona-evolution.md
# Cargo features + defaults: crates/openfang-runtime/README.md
#
# Structured turn extraction (ainl-graph-extractor path). Truthy: 1, true, yes, on
# AINL_EXTRACTOR_ENABLED=1
#
# Semantic tagger strings on episode + fact nodes. ONLY the literal "1" enables (not true/yes/on)
# AINL_TAGGER_ENABLED=1
#
# Extra persona axis nudge after evolution pass. Truthy: 1, true, yes, on
# AINL_PERSONA_EVOLUTION=1
#
# Optional writable DIRECTORY: Rust writes <dir>/<agent_id>_graph_export.json after each chat turn (persona evolution).
# When unset, exports go to ~/.armaraos/agents/<id>/ainl_graph_memory_export.json (same home as ainl_memory.db).
# Python ainl_graph_memory can read the same dir + ARMARAOS_AGENT_ID, or a single .json path — docs/graph-memory.md
# AINL_GRAPH_MEMORY_ARMARAOS_EXPORT=/path/to/writable/export_dir

# ─── OpenFang Configuration ──────────────────────────────────────────

# API server bind address (default: 127.0.0.1:3000)
# OPENFANG_LISTEN=127.0.0.1:3000

# API key for HTTP authentication (leave empty for localhost-only access)
# OPENFANG_API_KEY=

# Home directory (default: ~/.openfang)
# OPENFANG_HOME=~/.openfang

# Log level (default: info)
# RUST_LOG=info
# RUST_LOG=openfang=debug        # Debug OpenFang only

# ─── ArmaraOS Desktop — PostHog (optional overrides) ─────────────────────
# Release binaries embed the key at compile time. CI prefers ARMARAOS_POSTHOG_KEY or
# AINL_POSTHOG_KEY (same phc_… as ainativelang.com NEXT_PUBLIC_POSTHOG_KEY). See docs/release-desktop.md.
# Runtime vars below override the baked values (dev / air-gapped / debugging only).
# ARMARAOS_POSTHOG_KEY=phc_...
# AINL_POSTHOG_KEY=phc_...                         # alternate env name (matches CI fallback)
# ARMARAOS_POSTHOG_HOST=https://us.i.posthog.com   # or https://eu.i.posthog.com
# AINL_POSTHOG_HOST=https://us.i.posthog.com
# ARMARAOS_PRODUCT_ANALYTICS=0                     # force disable all product pings
# ARMARAOS_INSTALL_SOURCE=website                  # optional property on first-open event
#
# Embedded web dashboard — PostHog (compile-time for openfang-api). Same phc_ as ainativelangweb;
# release CI sets this alongside ARMARAOS_POSTHOG_KEY. Locally you only need one of these set when building:
# ARMARAOS_DASHBOARD_POSTHOG_KEY=phc_...
# (falls back to ARMARAOS_POSTHOG_KEY / AINL_POSTHOG_KEY if unset)
