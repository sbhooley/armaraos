<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>NSMicrophoneUsageDescription</key>
	<string>ArmaraOS uses the microphone when you hold the mic button to record a voice message for your agent.</string>
	<key>NSAppleEventsUsageDescription</key>
	<string>ArmaraOS uses Mail to compose support messages and attach your diagnostics zip when you choose Get Help.</string>
	<!--
	  CFBundleURLTypes registers the `armaraos://` URL scheme with macOS
	  LaunchServices. Without this, clicking `armaraos://premium-ainl?ticket=…`
	  in the system browser is a no-op and Premium verification can never
	  hand the ticket back to the desktop app.

	  Note: tauri-plugin-deep-link's build script only patches the *mobile*
	  Info.plist (iOS), not the macOS desktop bundle, so we register the
	  scheme manually here.
	-->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>ai.armaraos.desktop.premium</string>
			<key>CFBundleTypeRole</key>
			<string>Viewer</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>armaraos</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
